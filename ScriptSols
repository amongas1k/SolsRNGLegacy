-- ── ESP ──────────────────────────────────────────────────────────────────────
-- ══════════════════════════════════════════════════════════════════════════════
local useDrawing = pcall(function() local d = Drawing.new("Line"); d:Remove() end)
local espObjects = {}

local function getRarityColor(item)
    return rarityColors[item.Name] or espOutlineColor
end

local function createESP(item)
    if espObjects[item] then return end

    if useDrawing then
        local lines = {}
        for _ = 1, 4 do
            local line      = Drawing.new("Line")
            line.Visible    = false
            line.Color      = getRarityColor(item)
            line.Thickness  = 2
            table.insert(lines, line)
        end
        local text   = Drawing.new("Text")
        text.Visible = false
        text.Color   = espTextColor
        text.Size    = 18
        text.Font    = 2
        text.Center  = true

        local distText   = Drawing.new("Text")
        distText.Visible = false
        distText.Color   = Color3.fromRGB(200, 200, 200)
        distText.Size    = 14
        distText.Font    = 2
        distText.Center  = true

        espObjects[item] = {lines = lines, text = text, distText = distText}
    else
        local adornee = getPrimaryPart(item) or item
        if not adornee then return end

        local gui              = Instance.new("BillboardGui")
        gui.Size               = UDim2.new(4, 0, 4, 0)
        gui.AlwaysOnTop        = true
        gui.Adornee            = adornee
        gui.Parent             = item

        local frame                   = Instance.new("Frame")
        frame.Size                    = UDim2.new(1, 0, 1, 0)
        frame.BackgroundTransparency  = 1
        frame.BorderSizePixel         = 0

        local stroke          = Instance.new("UIStroke")
        stroke.Color          = getRarityColor(item)
        stroke.Thickness      = 2
        stroke.Parent         = frame
        frame.Parent          = gui

        local label                   = Instance.new("TextLabel")
        label.Size                    = UDim2.new(1, 0, 0, 28)
        label.Position                = UDim2.new(0, 0, -0.22, 0)
        label.AnchorPoint             = Vector2.new(0.5, 1)
        label.BackgroundTransparency  = 1
        label.TextColor3              = espTextColor
        label.TextSize                = 18
        label.Font                    = Enum.Font.GothamBold
        label.Text                    = item.Name
        label.Visible                 = showItemName
        label.Parent                  = gui

        local distLabel               = Instance.new("TextLabel")
        distLabel.Name                = "DistLabel"
        distLabel.Size                = UDim2.new(1, 0, 0, 20)
        distLabel.Position            = UDim2.new(0, 0, 1.05, 0)
        distLabel.BackgroundTransparency = 1
        distLabel.TextColor3          = Color3.fromRGB(180, 180, 180)
        distLabel.TextSize            = 13
        distLabel.Font                = Enum.Font.Gotham
        distLabel.Text                = ""
        distLabel.Visible             = showDistance
        distLabel.Parent              = gui

        espObjects[item] = gui
    end
end

local function removeESP(item)
    local obj = espObjects[item]
    if not obj then return end
    espObjects[item] = nil
    if useDrawing then
        pcall(function() for _, l in ipairs(obj.lines) do l:Remove() end end)
        pcall(function() obj.text:Remove()     end)
        pcall(function() obj.distText:Remove() end)
    else
        pcall(function() obj:Destroy() end)
    end
end

local function updateESP()
    -- Remove stale entries
    for item in pairs(espObjects) do
        if not item:IsDescendantOf(DROPPED_ITEMS_FOLDER) then
            removeESP(item)
        end
    end

    local needESP = espEnabled or showItemName or showDistance

    if not needESP then
        for _, obj in pairs(espObjects) do
            if useDrawing then
                for _, l in ipairs(obj.lines) do l.Visible = false end
                obj.text.Visible     = false
                obj.distText.Visible = false
            else
                obj.Enabled = false
            end
        end
        return
    end

    for _, item in ipairs(DROPPED_ITEMS_FOLDER:GetChildren()) do
        if not espObjects[item] then createESP(item) end
        local obj = espObjects[item]
        if not obj then continue end

        local dist = getDistanceTo(item)
        local distStr = string.format("%.0f studs", dist)

        if useDrawing then
            local prim = getPrimaryPart(item)
            if not prim then
                for _, l in ipairs(obj.lines) do l.Visible = false end
                obj.text.Visible     = false
                obj.distText.Visible = false
                continue
            end

            local cf, size = prim.CFrame, prim.Size
            local corners = {
                (cf * CFrame.new(-size.X/2, -size.Y/2, -size.Z/2)).Position,
                (cf * CFrame.new( size.X/2, -size.Y/2, -size.Z/2)).Position,
                (cf * CFrame.new( size.X/2,  size.Y/2, -size.Z/2)).Position,
                (cf * CFrame.new(-size.X/2,  size.Y/2, -size.Z/2)).Position,
                (cf * CFrame.new(-size.X/2, -size.Y/2,  size.Z/2)).Position,
                (cf * CFrame.new( size.X/2, -size.Y/2,  size.Z/2)).Position,
                (cf * CFrame.new( size.X/2,  size.Y/2,  size.Z/2)).Position,
                (cf * CFrame.new(-size.X/2,  size.Y/2,  size.Z/2)).Position,
            }

            local screenPoints = {}
            local anyBehind    = false
            for _, wp in ipairs(corners) do
                local sp, onScreen = camera:WorldToViewportPoint(wp)
                if not onScreen then anyBehind = true end
                table.insert(screenPoints, Vector2.new(sp.X, sp.Y))
            end

            if anyBehind then
                for _, l in ipairs(obj.lines) do l.Visible = false end
                obj.text.Visible     = false
                obj.distText.Visible = false
                continue
            end

            local minX, minY =  math.huge,  math.huge
            local maxX, maxY = -math.huge, -math.huge
            for _, sp in ipairs(screenPoints) do
                if sp.X < minX then minX = sp.X end
                if sp.Y < minY then minY = sp.Y end
                if sp.X > maxX then maxX = sp.X end
                if sp.Y > maxY then maxY = sp.Y end
            end

            local rcol = getRarityColor(item)

            if espEnabled then
                obj.lines[1].From, obj.lines[1].To = Vector2.new(minX, minY), Vector2.new(maxX, minY)
                obj.lines[2].From, obj.lines[2].To = Vector2.new(maxX, minY), Vector2.new(maxX, maxY)
                obj.lines[3].From, obj.lines[3].To = Vector2.new(maxX, maxY), Vector2.new(minX, maxY)
                obj.lines[4].From, obj.lines[4].To = Vector2.new(minX, maxY), Vector2.new(minX, minY)
                for _, l in ipairs(obj.lines) do
                    l.Visible = true
                    l.Color   = rcol
                end
            else
                for _, l in ipairs(obj.lines) do l.Visible = false end
            end

            local midX = (minX + maxX) / 2

            if showItemName then
                obj.text.Visible  = true
                obj.text.Text     = item.Name
                obj.text.Color    = rcol
                obj.text.Position = Vector2.new(midX, minY - 20)
            else
                obj.text.Visible = false
            end

            if showDistance then
                obj.distText.Visible  = true
                obj.distText.Text     = distStr
                obj.distText.Position = Vector2.new(midX, maxY + 4)
            else
                obj.distText.Visible = false
            end

        else
            -- BillboardGui path
            obj.Enabled = needESP

            local frame = obj:FindFirstChildOfClass("Frame")
            if frame then
                local stroke = frame:FindFirstChildOfClass("UIStroke")
                if stroke then
                    stroke.Color  = getRarityColor(item)
                    frame.Visible = espEnabled
                end
            end

            local label = obj:FindFirstChildWhichIsA("TextLabel")
            if label then
                label.Visible    = showItemName
                label.TextColor3 = espTextColor
                label.Text       = item.Name
            end

            local distLabel = obj:FindFirstChild("DistLabel")
            if distLabel then
                distLabel.Visible = showDistance
                distLabel.Text    = distStr
            end
        end
    end
end

DROPPED_ITEMS_FOLDER.ChildRemoved:Connect(function(child)
    removeESP(child)
    itemTasks[child] = nil
    processedItems[child] = nil
end)

RunService.RenderStepped:Connect(updateESP)

