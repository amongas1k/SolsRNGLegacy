local CONFIG_DIR    = "DroppedItemsHelper/Configs/"
local AUTOLOAD_FILE = CONFIG_DIR .. "autoload.json"

local function ensureDirs()
    pcall(function() makefolder("DroppedItemsHelper") end)
    pcall(function() makefolder("DroppedItemsHelper/Configs") end)
end

local function getSettingsTable()
    return {
        TELEPORT_HEIGHT    = TELEPORT_HEIGHT,
        HORIZONTAL_OFFSET  = HORIZONTAL_OFFSET,
        SPAWN_DELAY        = SPAWN_DELAY,
        TELEPORT_COOLDOWN  = TELEPORT_COOLDOWN,
        AUTO_FARM_INTERVAL = AUTO_FARM_INTERVAL,
        MAX_COLLECT_DIST   = MAX_COLLECT_DIST,
        autoCollectEnabled = autoCollectEnabled,
        teleportEnabled    = teleportEnabled,
        autoFarmEnabled    = autoFarmEnabled,
        espEnabled         = espEnabled,
        showItemName       = showItemName,
        showDistance       = showDistance,
        espOutlineColor    = color3ToTable(espOutlineColor),
        espTextColor       = color3ToTable(espTextColor),
        disable3DRendering = disable3DRendering,
        uiToggleKey        = keyCodeToString(uiToggleKey),
        panicKey           = keyCodeToString(panicKey),
        collectedCounts    = collectedCounts,
        itemWhitelist      = itemWhitelist,
        itemBlacklist      = itemBlacklist,
        totalCollected     = totalCollected,
    }
end

local function applySettings(tbl)
    if tbl.TELEPORT_HEIGHT    ~= nil then TELEPORT_HEIGHT    = tbl.TELEPORT_HEIGHT    end
    if tbl.HORIZONTAL_OFFSET  ~= nil then HORIZONTAL_OFFSET  = tbl.HORIZONTAL_OFFSET  end
    if tbl.SPAWN_DELAY        ~= nil then SPAWN_DELAY        = tbl.SPAWN_DELAY        end
    if tbl.TELEPORT_COOLDOWN  ~= nil then TELEPORT_COOLDOWN  = tbl.TELEPORT_COOLDOWN  end
    if tbl.AUTO_FARM_INTERVAL ~= nil then AUTO_FARM_INTERVAL = tbl.AUTO_FARM_INTERVAL end
    if tbl.MAX_COLLECT_DIST   ~= nil then MAX_COLLECT_DIST   = tbl.MAX_COLLECT_DIST   end
    if tbl.autoCollectEnabled ~= nil then autoCollectEnabled = tbl.autoCollectEnabled end
    if tbl.teleportEnabled    ~= nil then teleportEnabled    = tbl.teleportEnabled    end
    if tbl.autoFarmEnabled    ~= nil then autoFarmEnabled    = tbl.autoFarmEnabled    end
    if tbl.espEnabled         ~= nil then espEnabled         = tbl.espEnabled         end
    if tbl.showItemName       ~= nil then showItemName       = tbl.showItemName       end
    if tbl.showDistance       ~= nil then showDistance       = tbl.showDistance       end
    if tbl.espOutlineColor    ~= nil then espOutlineColor    = tableToColor3(tbl.espOutlineColor) end
    if tbl.espTextColor       ~= nil then espTextColor       = tableToColor3(tbl.espTextColor)    end
    if tbl.totalCollected     ~= nil then totalCollected     = tbl.totalCollected     end

    if tbl.disable3DRendering ~= nil then
        disable3DRendering = tbl.disable3DRendering
        set3DRendering(not disable3DRendering)
    end

    if tbl.uiToggleKey ~= nil then
        uiToggleKey = stringToKeyCode(tbl.uiToggleKey)
        if uiKeyLabel then uiKeyLabel:Set("UI Toggle Key: " .. uiToggleKey.Name) end
    end

    if tbl.panicKey ~= nil then
        panicKey = stringToKeyCode(tbl.panicKey)
        if panicKeyLabel then panicKeyLabel:Set("Panic Key: " .. panicKey.Name) end
    end

    if tbl.collectedCounts then
        for k, v in pairs(tbl.collectedCounts) do
            if collectedCounts[k] ~= nil then
                collectedCounts[k] = v
                updateCounter(k)
            end
        end
    end

    if tbl.itemWhitelist then
        for k, v in pairs(tbl.itemWhitelist) do itemWhitelist[k] = v end
    end
    if tbl.itemBlacklist then
        for k, v in pairs(tbl.itemBlacklist) do itemBlacklist[k] = v end
    end
end

local function getConfigList()
    local list = {}
    pcall(function()
        ensureDirs()
        for _, file in ipairs(listfiles(CONFIG_DIR)) do
            local name = file:match("([^/\\]+)%.json$")
            if name and name ~= "autoload" then
                table.insert(list, name)
            end
        end
    end)
    return list
end

updateConfigList = function()
    local list = getConfigList()
    if configDropdown then
        pcall(function() configDropdown:Refresh(list, true) end)
    end
end

local function saveConfig(name)
    ensureDirs()
    local ok, err = pcall(function()
        writefile(CONFIG_DIR .. name .. ".json", HttpService:JSONEncode(getSettingsTable()))
    end)
    if ok then
        notify("Config Saved", name .. ".json", Color3.fromRGB(60, 200, 120))
    else
        notify("Save Failed", tostring(err), Color3.fromRGB(255, 80, 80))
    end
    updateConfigList()
end

local function loadConfig(name)
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_DIR .. name .. ".json"))
    end)
    if ok and type(data) == "table" then
        applySettings(data)
        notify("Config Loaded", name, Color3.fromRGB(100, 160, 255))
    else
        notify("Load Failed", "Could not read " .. name, Color3.fromRGB(255, 80, 80))
    end
end

local function deleteConfig(name)
    pcall(function() delfile(CONFIG_DIR .. name .. ".json") end)
    updateConfigList()
    notify("Config Deleted", name, Color3.fromRGB(200, 80, 80))
end

local function setAutoload(name)
    ensureDirs()
    pcall(function()
        writefile(AUTOLOAD_FILE, HttpService:JSONEncode({autoload = name}))
    end)
end

local function clearAutoload()
    pcall(function() delfile(AUTOLOAD_FILE) end)
end

local function doAutoload()
    pcall(function()
        if isfile(AUTOLOAD_FILE) then
            local data = HttpService:JSONDecode(readfile(AUTOLOAD_FILE))
            if data and data.autoload then
                loadConfig(data.autoload)
            end
        end
    end)
end

