local function triggerPanic()
    panicEnabled       = true
    autoCollectEnabled = false
    teleportEnabled    = false
    autoFarmEnabled    = false
    espEnabled         = false
    showItemName       = false
    showDistance       = false

    for item in pairs(itemTasks) do
        itemTasks[item] = nil
    end

    notify("⚠ PANIC", "All features disabled", Color3.fromRGB(255, 60, 60))

    task.delay(0.5, function()
        panicEnabled = false
    end)
end

local mainGui   -- cache for the Orion ScreenGui

local function findMainGui()
    for _, gui in ipairs(player.PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and (gui.Name == "Orion" or gui.Name == "OrionLib") then
            mainGui = gui
            return
        end
    end
end

local function toggleUI()
    if mainGui then
        mainGui.Enabled = not mainGui.Enabled
    else
        findMainGui()
        if mainGui then
            mainGui.Enabled = not mainGui.Enabled
        end
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

    if waitingForKey then
        waitingForKey = false
        setUiToggleKey(input.KeyCode)
        return
    end

    if waitingForPanicKey then
        waitingForPanicKey = false
        setPanicKey(input.KeyCode)
        return
    end

    if input.KeyCode == panicKey then
        triggerPanic()
        return
    end

    if input.KeyCode == uiToggleKey then
        toggleUI()
    end
end)

