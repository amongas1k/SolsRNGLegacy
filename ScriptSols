-- ── State ──────────────────────────
local TELEPORT_HEIGHT = 2.5
local HORIZONTAL_OFFSET = 0
local SPAWN_DELAY = 1
local TELEPORT_COOLDOWN = 5
local lastTeleportTime = 0

local processedItems = {}
local itemTasks = {}

local autoCollectEnabled   = false
local teleportEnabled      = false
local espEnabled           = false
local showItemName         = false
local espOutlineColor      = Color3.fromRGB(255,255,255)
local espTextColor         = Color3.new(1,1,1)

-- Tracked items & counters
local trackedItems = {"Gilded Coin", "Lucky Potion", "Speed Potion", "Coin"}
local collectedCounts = {}
for _, name in ipairs(trackedItems) do
    collectedCounts[name] = 0
end

local counterLabels = {}

-- ── Utilities ──────────────────────
local function getPrompt(object)
    local prompt = object:FindFirstChildOfClass("ProximityPrompt")
    if prompt then return prompt end
    local casing = object:FindFirstChild("Casing")
    if casing then
        prompt = casing:FindFirstChildOfClass("ProximityPrompt")
    end
    return prompt
end

local function getPromptPart(prompt)
    local parent = prompt.Parent
    while parent do
        if parent:IsA("BasePart") then return parent end
        parent = parent.Parent
    end
    return nil
end

local function getPrimaryPart(item)
    if item:IsA("BasePart") then return item end
    if item:IsA("Model") then
        return item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
    end
    return item:FindFirstChildWhichIsA("BasePart")
end

local function toColor3(val)
    if typeof(val) == "Color3" then return val end
    if type(val) == "table" then
        return val.Color or Color3.new(1,1,1)
    end
    return Color3.new(1,1,1)
end

local function updateCounter(name)
    local lbl = counterLabels[name]
    if lbl then
        lbl:Set(name .. ": " .. collectedCounts[name])
    end
end

-- ── Scheduler ──────────────────────
local function scheduleTeleport(item)
    if itemTasks[item] then return end
    itemTasks[item] = true

    task.spawn(function()
        if SPAWN_DELAY > 0 then task.wait(SPAWN_DELAY) end

        if not item:IsDescendantOf(Workspace) then
            itemTasks[item] = nil; return
        end
        if processedItems[item] then
            itemTasks[item] = nil; return
        end

        local allowForwardTeleport = teleportEnabled and (tick() - lastTeleportTime >= TELEPORT_COOLDOWN)
        if not allowForwardTeleport and not autoCollectEnabled then
            itemTasks[item] = nil; return
        end

        local prompt = getPrompt(item)
        if not prompt or not prompt.Enabled then
            itemTasks[item] = nil; return
        end

        local promptPart = getPromptPart(prompt) or getPrimaryPart(item)
        if not promptPart then
            itemTasks[item] = nil; return
        end

        local character = player.Character
        if not character then itemTasks[item] = nil; return end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not rootPart then itemTasks[item] = nil; return end

        local originalCFrame = rootPart.CFrame
        local didTeleport = false

        if allowForwardTeleport then
            local targetCFrame = promptPart.CFrame * CFrame.new(HORIZONTAL_OFFSET, TELEPORT_HEIGHT, 0)
            pcall(function() character:PivotTo(targetCFrame) end)
            didTeleport = true
            lastTeleportTime = tick()
            task.wait(0.25)
        end

        if autoCollectEnabled and not processedItems[item] then
            local originalLOS = prompt.RequiresLineOfSight
            prompt.RequiresLineOfSight = false

            local triggered = false
            local conn
            pcall(function()
                conn = prompt.Triggered:Connect(function()
                    triggered = true
                    if conn then conn:Disconnect() end
                end)
            end)
            pcall(function() prompt:InputHoldBegin() end)

            local start = tick()
            while not triggered and tick() - start < 3 do
                RunService.Heartbeat:Wait()
            end

            if triggered then
                processedItems[item] = true
                local name = item.Name
                if collectedCounts[name] ~= nil then
                    collectedCounts[name] = collectedCounts[name] + 1
                    updateCounter(name)
                end
            end

            if conn then pcall(function() conn:Disconnect() end) end
            prompt.RequiresLineOfSight = originalLOS
        end

        if didTeleport then
            pcall(function() character:PivotTo(originalCFrame) end)
        end

        itemTasks[item] = nil
    end)
end

-- ── Detection ──────────────────────
local DROPPED_ITEMS_FOLDER = Workspace:WaitForChild("DroppedItems")

DROPPED_ITEMS_FOLDER.ChildAdded:Connect(function(child)
    if getPrompt(child) and not processedItems[child] then
        scheduleTeleport(child)
    end
end)

task.spawn(function()
    while true do
        task.wait(0.5)
        for _, child in ipairs(DROPPED_ITEMS_FOLDER:GetChildren()) do
            if getPrompt(child) and not processedItems[child] then
                scheduleTeleport(child)
            end
        end
    end
end)

