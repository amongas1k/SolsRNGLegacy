-- ── Utilities ─────────────────────────────────────────────────────────────────
-- ══════════════════════════════════════════════════════════════════════════════
local function getPrompt(object)
    local prompt = object:FindFirstChildOfClass("ProximityPrompt")
    if prompt then return prompt end
    local casing = object:FindFirstChild("Casing")
    if casing then
        return casing:FindFirstChildOfClass("ProximityPrompt")
    end
    return nil
end

local function getPromptPart(prompt)
    local parent = prompt.Parent
    local depth  = 0
    while parent and depth < 5 do
        if parent:IsA("BasePart") then return parent end
        parent = parent.Parent
        depth  = depth + 1
    end
    return nil
end

local function getPrimaryPart(item)
    if item:IsA("BasePart")  then return item end
    if item:IsA("Model") then
        return item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
    end
    return item:FindFirstChildWhichIsA("BasePart")
end

local function toColor3(val)
    if typeof(val) == "Color3" then return val end
    if type(val) == "table" and val.Color then return val.Color end
    return Color3.new(1, 1, 1)
end

local function updateCounter(name)
    local lbl = counterLabels[name]
    if lbl then
        lbl:Set(name .. ": " .. tostring(collectedCounts[name]))
    end
end

local function updateStats()
    local elapsed = tick() - sessionStart
    local rate    = elapsed > 0 and (totalCollected / (elapsed / 60)) or 0
    local mins    = math.floor(elapsed / 60)
    local secs    = math.floor(elapsed % 60)
    if statsRateLabel  then statsRateLabel:Set(string.format("Items/min: %.1f", rate))                  end
    if statsTotalLabel then statsTotalLabel:Set("Total Collected: " .. tostring(totalCollected))         end
    if statsTimeLabel  then statsTimeLabel:Set(string.format("Session Time: %02d:%02d", mins, secs))    end
end

-- check if an item is allowed by whitelist/blacklist
local function isItemAllowed(item)
    local name = item.Name
    if itemBlacklist[name] then return false end
    if next(itemWhitelist) ~= nil then
        return itemWhitelist[name] == true
    end
    return true
end

local function getDistanceTo(item)
    local character = player.Character
    if not character then return math.huge end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return math.huge end
    local part = getPrimaryPart(item)
    if not part then return math.huge end
    return (root.Position - part.Position).Magnitude
end

