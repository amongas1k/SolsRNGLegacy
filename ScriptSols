DROPPED_ITEMS_FOLDER.ChildAdded:Connect(function(child)
    if getPrompt(child) and not processedItems[child] then
        scheduleTeleport(child)
    end
end)

-- Regular scan (items that were present before script start)
task.spawn(function()
    while true do
        task.wait(0.5)
        if panicEnabled then continue end
        for _, child in ipairs(DROPPED_ITEMS_FOLDER:GetChildren()) do
            if getPrompt(child) and not processedItems[child] then
                scheduleTeleport(child)
            end
        end
    end
end)

-- Auto-Farm Loop
task.spawn(function()
    while true do
        task.wait(AUTO_FARM_INTERVAL)
        if not autoFarmEnabled or panicEnabled then continue end

        local sorted = getSortedItems()
        for _, item in ipairs(sorted) do
            if panicEnabled then break end
            scheduleTeleport(item)
            task.wait(0.05)
        end
    end
end)

-- Stats update loop
task.spawn(function()
    while true do
        task.wait(1)
        updateStats()
    end
end)

