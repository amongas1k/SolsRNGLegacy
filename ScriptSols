-- ── Core Scheduler ───────────────────────────────────────────────────────────
-- ══════════════════════════════════════════════════════════════════════════════

-- sort candidate items by distance (nearest first)
local function getSortedItems()
    local items = {}
    for _, child in ipairs(DROPPED_ITEMS_FOLDER and DROPPED_ITEMS_FOLDER:GetChildren() or {}) do
        if getPrompt(child) and not processedItems[child] and isItemAllowed(child) then
            local dist = getDistanceTo(child)
            if MAX_COLLECT_DIST <= 0 or dist <= MAX_COLLECT_DIST then
                table.insert(items, {item = child, dist = dist})
            end
        end
    end
    table.sort(items, function(a, b) return a.dist < b.dist end)
    local result = {}
    for _, entry in ipairs(items) do table.insert(result, entry.item) end
    return result
end

local DROPPED_ITEMS_FOLDER

local function scheduleTeleport(item)
    if itemTasks[item] then return end
    if panicEnabled      then return end
    if not isItemAllowed(item) then return end

    -- Distance check
    if MAX_COLLECT_DIST > 0 and getDistanceTo(item) > MAX_COLLECT_DIST then return end

    itemTasks[item] = true

    task.spawn(function()
        local ok, err = pcall(function()

            if SPAWN_DELAY > 0 then task.wait(SPAWN_DELAY) end
            if panicEnabled then return end
            if not item:IsDescendantOf(Workspace) then return end
            if processedItems[item] then return end

            local allowTeleport = teleportEnabled and (tick() - lastTeleportTime >= TELEPORT_COOLDOWN)
            if not allowTeleport and not autoCollectEnabled then return end

            local prompt = getPrompt(item)
            if not prompt or not prompt.Enabled then return end

            local promptPart = getPromptPart(prompt) or getPrimaryPart(item)
            if not promptPart then return end

            local character = player.Character
            if not character then return end
            local rootPart  = character:FindFirstChild("HumanoidRootPart")
            if not rootPart then return end

            local originalCFrame = rootPart.CFrame
            local didTeleport    = false

            if allowTeleport then
                local target = promptPart.CFrame * CFrame.new(HORIZONTAL_OFFSET, TELEPORT_HEIGHT, 0)
                pcall(function() character:PivotTo(target) end)
                didTeleport      = true
                lastTeleportTime = tick()
                task.wait(0.25)
            end

            if autoCollectEnabled and not processedItems[item] then
                local originalLOS = prompt.RequiresLineOfSight
                prompt.RequiresLineOfSight = false

                local triggered = false
                local conn
                pcall(function()
                    conn = prompt.Triggered:Connect(function()
                        triggered = true
                        pcall(function() conn:Disconnect() end)
                    end)
                end)
                pcall(function() prompt:InputHoldBegin() end)

                local start = tick()
                while not triggered and tick() - start < 3 do
                    RunService.Heartbeat:Wait()
                end

                if triggered then
                    processedItems[item] = true
                    local iname = item.Name
                    totalCollected = totalCollected + 1

                    if collectedCounts[iname] ~= nil then
                        collectedCounts[iname] = collectedCounts[iname] + 1
                        updateCounter(iname)
                    end

                    -- Notification on collect
                    notify(
                        "✦ Collected",
                        iname .. " (" .. (collectedCounts[iname] or "?") .. "x)",
                        rarityColors[iname] or DEFAULT_RARITY_COLOR
                    )
                end

                pcall(function() conn:Disconnect() end)
                pcall(function() prompt.RequiresLineOfSight = originalLOS end)
            end

            if didTeleport then
                pcall(function() character:PivotTo(originalCFrame) end)
            end

        end)

        if not ok then
            warn("[DIH] scheduleTeleport error:", err)
        end
        -- Always release the lock
        itemTasks[item] = nil
    end)
end

